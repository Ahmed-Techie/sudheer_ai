# Type casting

If we have int and we want to make it float, we use type casting
a = 1
type(a)
a = float(a)
a = 1
id(a)
a = 1.0
id(a)
type(a)
a = str(a)
print(a)
print(type(a))
print("monal")
pi = 3.14
pi_int = int(pi)
print(pi_int)
print(type(pi_int))
bool_1 = False
bool_int = int(bool_1)
print(bool_int)
print(type(bool_int))
